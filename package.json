{
  "name": "mygymjournal-webapp",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "doctor": "node scripts/doctor.mjs",
    "create:user": "node scripts/create-user.mjs",
    "mail:test": "node scripts/send-test-email.mjs",
    "test:e2e:write": "bash scripts/run-e2e-write.sh",
    "ops:finalize": "bash scripts/finalize-prod.sh",
    "typecheck": "tsc --noEmit --incremental false",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.44.5",
    "lucide-react": "^0.540.0",
    "next": "^16.0.0",
    "nodemailer": "^7.0.5",
    "postgres": "^3.4.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0"
  }
}
